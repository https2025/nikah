rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: wishes
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - message: string (required, 1-1000 chars)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidWish(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt']) &&
             data.keys().hasOnly(['name', 'message', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /wishes/{wishId} {
      // Allow anyone to read wishes
      allow read: if true;
      
      // Allow anyone to create a wish if it's valid
      allow create: if isValidWish(request.resource.data);
      
      // No updates or deletes allowed for guests
      allow update, delete: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
